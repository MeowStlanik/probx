# --- Public (safe for frontend / Vercel NEXT_PUBLIC_*) ---
NEXT_PUBLIC_CHAIN_ID=5042002
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_ARC_RPC_URLS=https://rpc.testnet.arc.network,https://arc-testnet.drpc.org
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
NEXT_PUBLIC_MICRO_BOOST_ENGINE_ADDRESS=0xA30dbf33d9ffbB6b3de349dEFDac434A73b9202b
NEXT_PUBLIC_LIQUIDITY_POOL_ADDRESS=0x65F3E2F861FC3E00d1b234A7661BdFfA3e85f4b2
NEXT_PUBLIC_MARKET_FACTORY_ADDRESS=0x4BF56aFB15BEAED7ffD74486631a1F87338241B3

# --- API server only (never prefix with NEXT_PUBLIC_) ---
PORT=3001
HOST=0.0.0.0
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_RPC_URLS=https://rpc.testnet.arc.network,https://arc-testnet.drpc.org
ARC_FROM_BLOCK=

# Resolver / admin / market-cycle signer (Arc gas in USDC)
# Required for auto BTC+weather cycle (create + resolve every ~2 min)
ORACLE_PRIVATE_KEY=
DEPLOYER_PRIVATE_KEY=
PRIVATE_KEY=
OWNER_PRIVATE_KEY=

# Market cycle: 60s open + 60s observation; local timer + client heartbeat on Vercel
MARKET_CYCLE_ENABLED=
MARKET_CYCLE_INTERVAL_MS=55000
# Protect /api/cron/auto-resolve (required when set: ?secret= or Authorization: Bearer).
# Use the same value on Vercel Production + external pinger (see docs/EXTERNAL_CRON.md).
# Production URL for pinger: https://probx-rosy.vercel.app (not deploy previews).
CRON_SECRET=
# Min interval between anonymous cron/cycle runs (gas-spam protection). Min 5000.
CRON_THROTTLE_MS=30000
# Comma-separated allowed CORS origins for the standalone API (default: *).
# Example: CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000
CORS_ORIGINS=
# Protects admin endpoints (create/resolve/cancel/reset/settle/simulate).
# REQUIRED in production — without it those endpoints stay open (local dev mode).
# Falls back to CRON_SECRET if unset. Enter the same value on the /admin page.
ADMIN_SECRET=

# Circle Developer-Controlled Wallets (server-side)
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=

# Optional: server CCTP fund from Base Sepolia treasury
CCTP_SOURCE_PRIVATE_KEY=
# Demo treasury caps (public endpoint): max USDC per call / per address per day
CCTP_DEMO_MAX_PER_CALL=10
CCTP_DEMO_DAILY_PER_ADDRESS=25
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# OTP / email login — recommended for inbox delivery to friends:
# Gmail App Password SMTP (best deliverability without buying a domain)
#   1) Google Account → Security → 2-Step Verification ON
#   2) App passwords → Mail → generate 16-char password
#   3) Set:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx   (app password, spaces ok)
# BREVO_FROM_EMAIL=you@gmail.com
# BREVO_FROM_NAME=ProbX Arc
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
BREVO_FROM_EMAIL=
BREVO_FROM_NAME=ProbX Arc
# Alternatives (weaker inbox placement without custom domain):
BREVO_API_KEY=
RESEND_API_KEY=
RESEND_FROM=
EMAIL_FROM=
# EMAIL_OTP_DEV_ECHO=1 shows code in UI (default when no provider configured)
EMAIL_OTP_DEV_ECHO=
EMAIL_OTP_REQUIRED=
# Dedicated secret for signing OTP tokens (HMAC). Without it OTP codes can be
# brute-forced offline from the token and email verification is bypassable.
OTP_HMAC_SECRET=
# Encrypts embedded session wallet private keys at rest (.runtime/session-wallets.json).
SESSION_WALLET_SECRET=
NODE_ENV=development

# --- Durable KV (Upstash Redis free tier; Vercel KV names also accepted) ---
# Persists email -> Circle wallet mapping and tx statuses across deploys.
# Without these, storage falls back to local files (fine for dev only).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# aliases (Vercel KV):
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# --- Performance / cycle toggles ---
# RPC_BATCH: 1 = prefer JSON-RPC batches with plain fallback per URL; 0 = plain only
RPC_BATCH=1
# MARKET_CYCLE_ON_TRAFFIC: 1 = kick cycle on site traffic (demo-data/markets); 0 = off
MARKET_CYCLE_ON_TRAFFIC=1
